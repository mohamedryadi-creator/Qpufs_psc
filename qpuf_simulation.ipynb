    "# -- Attaque 3 : Intercept-Resend\n",
    "\n",
    "def F_intercept_theory(K):\n",
    "    \"\"\"Fidelite theorique attendue pour la base aleatoire (CUE).\"\"\"\n",
    "    return 2.0 / (K + 1)\n",
    "\n",
    "\n",
    "def build_eve_challenge_intercept(C_k, mode='random', probs_oke=None):\n",
    "    \"\"\"\n",
    "    Genere le challenge d Eve par mesure sur une base aleatoire (ou OKE).\n",
    "\n",
    "    Optimisations :\n",
    "    - 'random' : par invariance de Haar, U+C_k est uniforme sur la sphere ;\n",
    "      on le genere directement en O(K) sans QR KxK (O(K3)).\n",
    "    - 'oke'    : les probabilites P(j)=|Vh@C_k|^2 sont pre-calculees hors boucle.\n",
    "\n",
    "    Returns : (C_eve, fidelity)\n",
    "    \"\"\"\n",
    "    K_dim = len(C_k)\n",
    "    if mode == 'random':\n",
    "        # U+C_k ~ Uniforme(S^{2K-1}) par invariance de Haar\n",
    "        w     = np.random.randn(K_dim) + 1j * np.random.randn(K_dim)\n",
    "        w    /= np.linalg.norm(w)\n",
    "        probs = np.abs(w) ** 2\n",
    "    else:\n",
    "        probs = probs_oke   # pre-calcule une fois hors boucle\n",
    "\n",
    "    probs  = probs / probs.sum()\n",
    "    idx    = np.random.choice(K_dim, p=probs)\n",
    "    amp    = np.sqrt(probs[idx])\n",
    "\n",
    "    # C_eve avec |<C_eve, C_k>|^2 = probs[idx], en O(K)\n",
    "    v      = np.random.randn(K_dim) + 1j * np.random.randn(K_dim)\n",
    "    v     -= (v @ C_k.conj()) * C_k\n",
    "    C_perp = v / np.linalg.norm(v)\n",
    "    C_eve  = amp * C_k + np.sqrt(max(1.0 - probs[idx], 0.0)) * C_perp\n",
    "    C_eve /= np.linalg.norm(C_eve)\n",
    "\n",
    "    return C_eve, float(probs[idx])\n",
    "\n",
    "\n",
    "def mu_eve_intercept(n_ph, K_modes, eta, ldc):\n",
    "    \"\"\"Photons moyens pour Eve (attaque intercept-resend, base aleatoire).\"\"\"\n",
    "    return eta * n_ph * F_intercept_theory(K_modes) + ldc\n",
    "\n",
    "\n",
    "# -- Pre-calcul SVD pour OKE (fait UNE SEULE fois, hors boucle)\n",
    "print(\"Pre-calcul SVD de H pour OKE...\", end=\" \", flush=True)\n",
    "_, _, Vh_H     = np.linalg.svd(H, full_matrices=False)\n",
    "probs_oke_ref  = np.abs(Vh_H @ challenges[0]) ** 2\n",
    "probs_oke_ref /= probs_oke_ref.sum()\n",
    "print(\"OK\")\n",
    "\n",
    "# -- Verification Monte-Carlo de la fidelite (rapide : O(K) par tirage)\n",
    "n_mc   = 500\n",
    "C_ref3 = challenges[0]\n",
    "\n",
    "fids_random = []\n",
    "fids_oke    = []\n",
    "for _ in range(n_mc):\n",
    "    _, f_r = build_eve_challenge_intercept(C_ref3, mode='random')\n",
    "    fids_random.append(f_r)\n",
    "    # OKE : simple tirage dans les probas pre-calculees\n",
    "    j = np.random.choice(K, p=probs_oke_ref)\n",
    "    fids_oke.append(float(probs_oke_ref[j]))\n",
    "\n",
    "F3_theory = F_intercept_theory(K)\n",
    "print(\"Attaque 3 (Intercept-Resend) — fidelite empirique vs theorie :\")\n",
    "print(f\"  F3 theorie (base aleatoire) = 2/(K+1) = {F3_theory:.6f}\")\n",
    "print(f\"  F3 simulee (base aleatoire) = {np.mean(fids_random):.6f}  (std={np.std(fids_random):.6f})\")\n",
    "print(f\"  F_OKE simulee               = {np.mean(fids_oke):.6f}  (std={np.std(fids_oke):.6f})\")\n",
    "print(f\"  mu_Alice = {mu_alice(n, eta, lambda_dc):.4f}\")\n",
    "print(f\"  mu_Eve   = {mu_eve_intercept(n, K, eta, lambda_dc):.8f}\")\n",
    "\n",
    "# -- P_fp / P_fn analytique\n",
    "R_vals3 = R_grid\n",
