   "source": [
    "### 4.2 Distribution des valeurs singulières — Loi de Marchenko-Pastur\n",
    "\n",
    "Pour une matrice carrée $\\frac{1}{\\sqrt{N}}G$ avec entrées i.i.d. de variance $\\sigma^2$, la distribution empirique des valeurs singulières converge vers la loi du quart de cercle : $p(s) = \\frac{2}{\\pi \\sigma^2}\\sqrt{\\sigma^2 - (s - \\sigma)^2}$ dans $[0, 2\\sigma]$."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "20cf865c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "N_mp = 400\n",
    "sigma_mp = 1.0\n",
    "\n",
    "G = (sigma_mp / np.sqrt(2 * N_mp)) * (np.random.randn(N_mp, N_mp) + 1j * np.random.randn(N_mp, N_mp))\n",
    "sv = np.linalg.svd(G, compute_uv=False)\n",
    "\n",
    "# Marchenko-Pastur for square matrix (gamma=1): quarter-circle on [0, 2*sigma]\n",
    "s_th = np.linspace(0.01, 2 * sigma_mp - 0.01, 500)\n",
    "mp_density = (2 / (np.pi * sigma_mp**2)) * np.sqrt(np.maximum(4 * sigma_mp**2 - s_th**2, 0))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "ax.hist(sv, bins=40, density=True, alpha=0.6, color='#3498db', edgecolor='white',\n",
    "        label='Empirique')\n",
    "ax.plot(s_th, mp_density, 'r-', lw=2.5, label='Marchenko-Pastur (quart de cercle)')\n",
    "ax.axvline(sigma_mp, color='grey', ls=':', lw=1.5, label=rf'$\\sigma = {sigma_mp}$')\n",
    "ax.set_xlabel(r\"Valeur singulière $s$\", fontsize=13)\n",
    "ax.set_ylabel(\"Densité\", fontsize=13)\n",
    "ax.set_title(f\"Distribution des valeurs singulières (N={N_mp})\", fontsize=14, fontweight='bold')\n",
    "ax.legend(fontsize=11)\n",
    "ax.grid(True, alpha=0.25, ls='--')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
