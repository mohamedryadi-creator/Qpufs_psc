    }
   ],
   "source": [
    "Ns = np.arange(20, 520, 20)\n",
    "sigmas_test = [0.5, 1.0, 2.0]\n",
    "n_trials = 10\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "\n",
    "for sigma, color in zip(sigmas_test, ['#2ecc71', '#3498db', '#e74c3c']):\n",
    "    rho_mean = []\n",
    "    rho_std = []\n",
