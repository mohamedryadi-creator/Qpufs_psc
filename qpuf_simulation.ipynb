   "source": [
    "# -- Attaque 4 : Quadrature / Hétérodyne\n",
    "\n",
    "def F_quadrature(n, K):\n",
    "    \"\"\"Fidélité de l'attaque quadrature (détection hétérodyne).\"\"\"\n",
    "    return 2.0 * n / (2.0 * n + K)\n",
    "\n",
    "\n",
    "def build_eve_challenge_quadrature(C_k, n_ph):\n",
    "    \"\"\"\n",
    "    Génère le challenge estimé d'Eve par mesure hétérodyne.\n",
    "    Bruit complexe gaussien : sigma = 1/(2*sqrt(n)) par composante.\n",
    "    \"\"\"\n",
    "    sigma = 1.0 / (2.0 * np.sqrt(n_ph))\n",
    "    noise = sigma * (np.random.randn(len(C_k)) + 1j * np.random.randn(len(C_k)))\n",
    "    C_noisy = C_k + noise\n",
    "    return C_noisy / np.linalg.norm(C_noisy)\n",
    "\n",
    "\n",
    "def mu_eve_quadrature(n_ph, K_modes, eta, ldc):\n",
    "    \"\"\"Photons moyens pour Eve (attaque quadrature).\"\"\"\n",
    "    return eta * n_ph * F_quadrature(n_ph, K_modes) + ldc\n",
    "\n",
    "\n",
    "# -- Vérification de la fidélité\n",
    "C_ref4    = challenges[0]\n",
    "fids_quad = [abs(build_eve_challenge_quadrature(C_ref4, n) @ C_ref4.conj())**2\n",
    "              for _ in range(500)]\n",
    "F4_theory = F_quadrature(n, K)\n",
    "print(\"Attaque 4 (Quadrature hétérodyne) — fidélité empirique vs théorie :\")\n",
    "print(f\"  F4 théorie = 2n/(2n+K) = {F4_theory:.6f}\")\n",
    "print(f\"  F4 simulée (moy. 500 essais) = {np.mean(fids_quad):.6f}\")\n",
    "print(f\"  mu_Alice = {mu_alice(n, eta, lambda_dc):.4f}\")\n",
    "print(f\"  mu_Eve   = {mu_eve_quadrature(n, K, eta, lambda_dc):.6f}\")\n",
    "\n",
    "# -- P_fp et P_fn vs rounds\n",
    "inv_S_vals4 = [0.1, 0.3, 0.5, 0.8]\n",
    "colors_a4   = ['#8e44ad', '#2980b9', '#27ae60', '#d35400']\n",
    "R_vals4     = R_grid\n",
    "\n",
    "fig, axes4 = plt.subplots(1, 2, figsize=(14, 5))\n",
