    "def build_eve_challenge(C_k, S):\n",
    "    \"\"\"\n",
    "    Construit la meilleure estimation d'Eve via Gram-Schmidt.\n",
    "    Vérifie : |<C_Eve, C_k>|² = 1/(S+1)\n",
    "    \"\"\"\n",
    "    N_dim = len(C_k)\n",
    "    v = np.random.randn(N_dim) + 1j * np.random.randn(N_dim)\n",
    "    v -= (v @ C_k.conj()) * C_k          # projection orthogonale à C_k\n",
    "    C_perp = v / np.linalg.norm(v)\n",
    "\n",
    "    alpha = np.sqrt(1.0 / (S + 1))\n",
    "    beta  = np.sqrt(S   / (S + 1))\n",
    "    C_eve = alpha * C_k + beta * C_perp\n",
    "    C_eve /= np.linalg.norm(C_eve)       # sécurité numérique\n",
    "    return C_eve\n",
    "\n",
    "\n",
    "# ── Vérification du produit scalaire ─────────────────────────────────────────\n",
    "print(\"Vérification |<C_Eve, C_k>|² = 1/(S+1) :\")\n",
    "k_test = 0\n",
    "C_ref = challenges[k_test]\n",
    "for inv_s in [0.1, 0.3, 0.5, 0.8, 1.0]:\n",
    "    n_ph  = inv_s * K\n",
    "    S_val = K / n_ph\n",
    "    C_eve = build_eve_challenge(C_ref, S_val)\n",
    "    overlap = abs(C_eve @ C_ref.conj())**2\n",
    "    theory  = 1.0 / (S_val + 1)\n",
    "    print(f\"  1/S={inv_s:.1f}  →  |<C_Eve,C_k>|² = {overlap:.4f}  (théorie : {theory:.4f})\")\n",
    "\n",
    "# ── Comparaison des distributions Poisson sur 1 round ────────────────────────\n",
    "inv_S_demo = [0.1, 0.3, 0.5, 0.8]\n",
    "x_counts   = np.arange(0, 35)\n",
    "\n",
    "fig, axes = plt.subplots(1, len(inv_S_demo), figsize=(16, 4), sharey=False)\n",
