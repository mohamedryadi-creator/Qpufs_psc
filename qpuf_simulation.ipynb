    "    \"\"\"Photons moyens pour Eve (attaque POVM). poisson=True : n suit Poisson.\"\"\"\n",
    "    F = F_povm_poisson(n_ph, K_modes) if poisson else F_povm(n_ph, K_modes)\n",
