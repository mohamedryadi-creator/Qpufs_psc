    "def compute_contrast(counts, k):\n",
    "    background = np.delete(counts, k)\n",
    "    mean_bg = np.mean(background)\n",
    "    if mean_bg == 0:\n",
    "        return counts[k]\n",
    "    return counts[k] / mean_bg\n",
    "\n",
    "\n",
    "contrast_bon = []\n",
    "contrast_mauvais = []\n",
    "\n",
    "for _ in range(runs):\n",
    "    k_bon = np.random.randint(N)\n",
    "    y_bon = propagate(H, challenges[k_bon])\n",
    "    counts_bon = photon_detection(y_bon, n, eta, lambda_dc)\n",
    "    contrast_bon.append(compute_contrast(counts_bon, k_bon))\n",
    "\n",
    "    j = np.random.randint(N)\n",
    "    k_mauv = (j + np.random.randint(1, N)) % N\n",
    "    y_mauv = propagate(H, challenges[j])\n",
    "    counts_mauv = photon_detection(y_mauv, n, eta, lambda_dc)\n",
    "    contrast_mauvais.append(compute_contrast(counts_mauv, k_mauv))\n",
    "\n",
    "contrast_bon = np.array(contrast_bon)\n",
