   "source": [
    "Ns_cond = np.arange(20, 520, 20)\n",
    "n_trials_cond = 10\n",
    "\n",
    "kappa_unitary_mean, kappa_nonunitary_mean = [], []\n",
    "kappa_unitary_std, kappa_nonunitary_std = [], []\n",
    "\n",
    "for Ni in Ns_cond:\n",
    "    ku, knu = [], []\n",
    "    for _ in range(n_trials_cond):\n",
    "        Hu = generate_scattering_matrix(Ni, unitary=True)\n",
    "        Hnu = generate_scattering_matrix(Ni, unitary=False, sigma=1.0, alpha=0.95)\n",
    "        ku.append(np.linalg.cond(Hu))\n",
    "        knu.append(np.linalg.cond(Hnu))\n",
    "    kappa_unitary_mean.append(np.mean(ku))\n",
    "    kappa_unitary_std.append(np.std(ku))\n",
    "    kappa_nonunitary_mean.append(np.mean(knu))\n",
    "    kappa_nonunitary_std.append(np.std(knu))\n",
    "\n",
    "kappa_unitary_mean = np.array(kappa_unitary_mean)\n",
    "kappa_nonunitary_mean = np.array(kappa_nonunitary_mean)\n",
    "kappa_unitary_std = np.array(kappa_unitary_std)\n",
    "kappa_nonunitary_std = np.array(kappa_nonunitary_std)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
