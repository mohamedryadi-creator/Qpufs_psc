      "Fonctions A5 (partial knowledge) définies.\n",
      "F_partial(0.0) = 1.0000  (attendu : 1.0)\n",
      "F_partial(0.5) = 0.7500  (attendu : 0.75)\n",
      "F_partial(1.0) = 0.0000  (attendu : 0.0)\n"
     ]
    }
   ],
   "source": [
    "# -- Attaque 5 : fonctions utilitaires (partial knowledge of H)\n",
    "\n",
    "def F_partial(epsilon):\n",
    "    \"\"\"Fidélité théorique : F_5(eps) = 1 - eps^2.\"\"\"\n",
    "    return 1.0 - epsilon**2\n",
    "\n",
    "\n",
    "def build_eve_H_partial(H_true, epsilon):\n",
    "    \"\"\"\n",
    "    Génère H_hat = sqrt(1-eps^2)*H + eps*W,\n",
    "    où W est normalisée par son rayon spectral (identique à H non-unitaire).\n",
    "    \"\"\"\n",
    "    K = H_true.shape[0]\n",
    "    W_raw = (np.random.randn(K, K) + 1j * np.random.randn(K, K)) / np.sqrt(2 * K)\n",
    "    # Rayon spectral approx = 1 par loi circulaire (K=1600 >> 1)\n",
    "    rho_W = 1.0\n",
    "    W_norm = W_raw / rho_W\n",
    "    return np.sqrt(1.0 - epsilon**2) * H_true + epsilon * W_norm\n",
    "\n",
    "\n",
    "def build_eve_challenge_partial(H_true, k, epsilon):\n",
    "    \"\"\"Challenge d'Eve à partir de sa version bruitée de H.\"\"\"\n",
    "    H_hat = build_eve_H_partial(H_true, epsilon)\n",
    "    ek = np.zeros(H_true.shape[0], dtype=complex)\n",
    "    ek[k] = 1.0\n",
    "    v = H_hat.conj().T @ ek\n",
    "    return v / np.linalg.norm(v)\n",
    "\n",
    "\n",
    "def mu_eve_partial(n_ph, eta, ldc, epsilon):\n",
    "    \"\"\"Photons moyens d'Eve au pixel cible (partial knowledge).\"\"\"\n",
    "    return eta * n_ph * F_partial(epsilon) + ldc\n",
    "\n",
    "\n",
    "def F_partial_empirical(H_true, epsilon, n_samples=30):\n",
    "    \"\"\"\n",
    "    Estime empiriquement |<C_hat_k, C_k>|^2 par moyenne sur n_samples\n",
    "    réalisations de W et de l'indice k.\n",
    "    \"\"\"\n",
    "    K = H_true.shape[0]\n",
    "    fids = []\n",
    "    for _ in range(n_samples):\n",
    "        k = np.random.randint(K)\n",
    "        ek = np.zeros(K, dtype=complex)\n",
    "        ek[k] = 1.0\n",
    "        # Vrai challenge\n",
    "        v_true = H_true.conj().T @ ek\n",
    "        C_k = v_true / np.linalg.norm(v_true)\n",
    "        # Challenge d'Eve\n",
    "        C_hat = build_eve_challenge_partial(H_true, k, epsilon)\n",
    "        fids.append(abs(np.dot(C_hat.conj(), C_k))**2)\n",
    "    return float(np.mean(fids))\n",
    "\n",
    "\n",
    "print('Fonctions A5 (partial knowledge) définies.')\n",
    "print(f'F_partial(0.0) = {F_partial(0.0):.4f}  (attendu : 1.0)')\n",
    "print(f'F_partial(0.5) = {F_partial(0.5):.4f}  (attendu : 0.75)')\n",
    "print(f'F_partial(1.0) = {F_partial(1.0):.4f}  (attendu : 0.0)')\n"
   ]
  },
