   "source": [
    "### 4.3 Statistique d'espacement des valeurs propres (GUE)\n",
    "\n",
    "Pour les matrices aléatoires complexes (ensemble GUE), l'espacement entre valeurs propres voisines suit la distribution de Wigner : $p(s) = \\frac{32}{\\pi^2} s^2 e^{-4s^2/\\pi}$. Cela traduit la **répulsion des niveaux** — les valeurs propres ne se regroupent pas."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "f8c2702b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "N_gue = 300\n",
    "G = (1.0 / np.sqrt(2 * N_gue)) * (np.random.randn(N_gue, N_gue) + 1j * np.random.randn(N_gue, N_gue))\n",
    "eigvals = np.linalg.eigvals(G)\n",
    "\n",
    "angles = np.angle(eigvals)\n",
    "radii = np.abs(eigvals)\n",
    "\n",
    "sorted_angles = np.sort(angles)\n",
    "spacings_raw = np.diff(sorted_angles)\n",
    "\n",
    "mean_spacing = np.mean(spacings_raw)\n",
    "spacings_norm = spacings_raw / mean_spacing\n",
    "\n",
    "# Wigner surmise for GUE: p(s) = (32/pi^2) s^2 exp(-4s^2/pi)\n",
    "s_w = np.linspace(0, 4, 200)\n",
    "wigner_gue = (32 / np.pi**2) * s_w**2 * np.exp(-4 * s_w**2 / np.pi)\n",
    "\n",
    "# Poisson (uncorrelated): p(s) = exp(-s)\n",
    "poisson_spacing = np.exp(-s_w)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "ax.hist(spacings_norm, bins=50, density=True, alpha=0.6, color='#9b59b6',\n",
    "        edgecolor='white', label='Empirique (angles)')\n",
    "ax.plot(s_w, wigner_gue, 'r-', lw=2.5, label='Wigner (GUE)')\n",
    "ax.plot(s_w, poisson_spacing, 'g--', lw=2, label='Poisson (non-corrélé)')\n",
    "ax.set_xlabel(r\"Espacement normalisé $s$\", fontsize=13)\n",
    "ax.set_ylabel(\"Densité\", fontsize=13)\n",
    "ax.set_title(f\"Espacement des valeurs propres — Répulsion de niveaux (N={N_gue})\",\n",
    "             fontsize=14, fontweight='bold')\n",
    "ax.legend(fontsize=11)\n",
    "ax.set_xlim(0, 4)\n",
    "ax.grid(True, alpha=0.25, ls='--')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
