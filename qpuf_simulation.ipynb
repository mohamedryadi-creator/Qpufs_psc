    "# -- Attaque 1 : Clonage Quantique UQCM\n",
    "\n",
    "def F_cloning(n, K):\n",
    "    \"\"\"Fidélité du clone UQCM optimal (Brüß-Macchiavello).\"\"\"\n",
    "    return (n + 1) / (n + K)\n",
    "\n",
    "\n",
    "def build_eve_challenge_cloning(C_k, n, K):\n",
    "    \"\"\"\n",
    "    Génère le challenge d'Eve avec fidélité F_1 = (n+1)/(n+K).\n",
    "    Utilise la décomposition Gram-Schmidt : C_Eve = sqrt(F)*C_k + sqrt(1-F)*C_perp\n",
    "    \"\"\"\n",
    "    F = F_cloning(n, K)\n",
    "    v  = np.random.randn(len(C_k)) + 1j * np.random.randn(len(C_k))\n",
    "    v -= (v @ C_k.conj()) * C_k          # projection orthogonale à C_k\n",
    "    C_perp = v / np.linalg.norm(v)\n",
    "    C_eve  = np.sqrt(F) * C_k + np.sqrt(1 - F) * C_perp\n",
    "    return C_eve / np.linalg.norm(C_eve)\n",
    "\n",
    "\n",
    "def mu_eve_cloning(n_ph, K_modes, eta, ldc):\n",
    "    \"\"\"Photons moyens pour Eve (attaque clonage).\"\"\"\n",
    "    return eta * n_ph * F_cloning(n_ph, K_modes) + ldc\n",
    "\n",
    "\n",
    "# -- Vérification de la fidélité\n",
    "k_demo   = 0\n",
    "C_ref    = challenges[k_demo]\n",
    "overlaps = []\n",
    "for _ in range(200):\n",
    "    C_eve = build_eve_challenge_cloning(C_ref, n, K)\n",
    "    overlaps.append(abs(C_eve @ C_ref.conj())**2)\n",
    "F1_theory = F_cloning(n, K)\n",
    "print(f\"Attaque 1 (UQCM) — vérification fidélité :\")\n",
    "print(f\"  F_théorie = (n+1)/(n+K) = {F1_theory:.6f}\")\n",
    "print(f\"  F_simulée (moy. 200 essais) = {np.mean(overlaps):.6f}\")\n",
    "print(f\"  mu_Alice = {mu_alice(n, eta, lambda_dc):.4f}\")\n",
    "print(f\"  mu_Eve   = {mu_eve_cloning(n, K, eta, lambda_dc):.6f}\")\n",
    "\n",
    "# -- P_fp et P_fn vs rounds\n",
    "inv_S_vals = [0.1, 0.3, 0.5, 0.8]\n",
    "R_vals     = R_grid\n",
    "colors_a1  = ['#1abc9c', '#3498db', '#e74c3c', '#f39c12']\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
