    "## 11. Validation Monte Carlo des probabilités d'erreur\n",
    "\n",
    "On vérifie que les formules analytiques (CDF de Poisson) reproduisent bien\n",
    "les taux d'erreur observés en simulation directe.\n",
    "Pour chaque attaque, on simule `n_mc_runs` authentifications Alice et tentatives Eve,\n",
    "et on compare $P_{\\mathrm{fp}}^{\\mathrm{sim}}$ vs $P_{\\mathrm{fp}}^{\\mathrm{anal}}$."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "9833cf14",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Fonctions de validation Monte Carlo définies.\n"
     ]
    }
   ],
   "source": [
    "# -- Simulation directe d'une authentification sur R rounds\n",
    "def simulate_auth_score(H, C_k, k_idx, n_ph, eta, ldc, R):\n",
    "    \"\"\"Score total d'Alice sur R rounds (somme des photons au pixel k).\"\"\"\n",
    "    total = 0\n",
    "    for _ in range(R):\n",
    "        y     = propagate(H, C_k)\n",
    "        counts = photon_detection(y, n_ph, eta, ldc)\n",
    "        total += counts[k_idx]\n",
    "    return total\n",
    "\n",
    "def mc_error_rates(H, challenges, k_idx, build_eve_fn,\n",
    "                   n_ph, eta, ldc, R, T_star, n_mc=3000):\n",
    "    \"\"\"\n",
    "    Simule n_mc authentifications Alice et n_mc tentatives Eve.\n",
    "    Retourne P_fp_mc (Eve acceptée), P_fn_mc (Alice rejetée).\n",
    "    build_eve_fn(C_k) -> C_eve\n",
    "    \"\"\"\n",
    "    C_k   = challenges[k_idx]\n",
    "    accept_alice = 0\n",
    "    accept_eve   = 0\n",
    "    for _ in range(n_mc):\n",
    "        # Alice\n",
    "        score_a = simulate_auth_score(H, C_k, k_idx, n_ph, eta, ldc, R)\n",
    "        if score_a >= T_star:\n",
    "            accept_alice += 1\n",
    "        # Eve\n",
    "        C_eve = build_eve_fn(C_k)\n",
    "        score_e = simulate_auth_score(H, C_eve, k_idx, n_ph, eta, ldc, R)\n",
    "        if score_e >= T_star:\n",
