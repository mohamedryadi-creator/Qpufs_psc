    "\n",
    "\n",
    "def F_povm_poisson(n_av, K):\n",
    "    \"\"\"Fidélité POVM pour n Poisson(n_av) — approximation du papier Skoric.\"\"\"\n",
    "    return (n_av + 1) / (n_av + K)\n",
    "\n",
    "\n",
