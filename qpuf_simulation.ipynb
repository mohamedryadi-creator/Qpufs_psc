   "source": [
    "def compute_error_probs(n_ph, K_modes, eta, ldc, R):\n",
    "    \"\"\"\n",
    "    Calcule analytiquement P_fp et P_fn optimaux pour R rounds.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    n_ph    : float  — photons moyens par impulsion\n",
    "    K_modes : int    — nombre de modes\n",
    "    eta     : float  — efficacité\n",
    "    ldc     : float  — dark counts\n",
    "    R       : int    — nombre de rounds\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    P_fp_opt, P_fn_opt : float\n",
    "    T_star             : int   — seuil optimal\n",
    "    \"\"\"\n",
    "    lam_A = R * mu_alice(n_ph, eta, ldc)\n",
    "    lam_E = R * mu_eve(n_ph, K_modes, eta, ldc)\n",
    "\n",
    "    # Borne supérieure sûre pour le seuil\n",
    "    T_max = int(lam_A + 8 * np.sqrt(max(lam_A, 1)) + 30)\n",
    "    T_range = np.arange(0, T_max + 2)\n",
    "\n",
    "    # scipy_poisson.cdf(-1, λ) = 0, donc P_fp(T=0)=1 : correct\n",
    "    P_fp = 1.0 - scipy_poisson.cdf(T_range - 1, lam_E)\n",
    "    P_fn = scipy_poisson.cdf(T_range - 1, lam_A)\n",
    "\n",
    "    worst = np.maximum(P_fp, P_fn)\n",
    "    idx   = np.argmin(worst)\n",
    "    return float(P_fp[idx]), float(P_fn[idx]), int(T_range[idx])\n",
    "\n",
    "\n",
    "# ── Démonstration : courbes d'erreur vs seuil T ──────────────────────────────\n",
    "n_demo  = 0.3 * K     # 1/S = 0.3\n",
    "R_demo  = 10\n",
    "\n",
    "lam_A_d = R_demo * mu_alice(n_demo, eta_sec, ldc_sec)\n",
    "lam_E_d = R_demo * mu_eve(n_demo, K, eta_sec, ldc_sec)\n",
    "\n",
    "T_plot  = np.arange(0, int(lam_A_d + 6 * np.sqrt(lam_A_d)) + 10)\n",
    "Pfp_d   = 1.0 - scipy_poisson.cdf(T_plot - 1, lam_E_d)\n",
    "Pfn_d   = scipy_poisson.cdf(T_plot - 1, lam_A_d)\n",
    "\n",
    "Pstar_fp, Pstar_fn, T_star_d = compute_error_probs(n_demo, K, eta_sec, ldc_sec, R_demo)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "ax.semilogy(T_plot, Pfp_d, 'r-', lw=2, label=r'$P_\\mathrm{fp}(T)$ — Eve acceptée')\n",
    "ax.semilogy(T_plot, Pfn_d, 'b-', lw=2, label=r'$P_\\mathrm{fn}(T)$ — Alice rejetée')\n",
    "ax.axvline(T_star_d, color='grey', ls='--', lw=1.5,\n",
    "           label=f'$T^*={T_star_d}$  '\n",
    "                 f'($P_{{fp}}$={Pstar_fp:.2e}, $P_{{fn}}$={Pstar_fn:.2e})')\n",
    "ax.scatter([T_star_d], [max(Pstar_fp, Pstar_fn)], c='black', s=80, zorder=5)\n",
    "ax.set_xlabel(r'Seuil $T$', fontsize=13)\n",
    "ax.set_ylabel('Probabilité', fontsize=13)\n",
    "ax.set_title(f'Courbes d\\'erreur vs seuil  (1/S = {n_demo/K:.1f}, R = {R_demo} rounds)',\n",
    "             fontsize=13, fontweight='bold')\n",
    "ax.legend(fontsize=10)\n",
    "ax.grid(True, alpha=0.25, ls='--', which='both')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f\"\\nDémonstration (1/S={n_demo/K:.1f}, R={R_demo}) :\")\n",
    "print(f\"  λ_Alice = {lam_A_d:.2f},  λ_Eve = {lam_E_d:.2f}\")\n",
    "print(f\"  T* = {T_star_d},  P_fp = {Pstar_fp:.3e},  P_fn = {Pstar_fn:.3e}\")"
   ]
  },
