     "name": "stdout",
     "output_type": "stream",
     "text": [
      "M =    10  erreur relative = 0.9937\n",
      "M =    50  erreur relative = 0.9686\n",
      "M =   100  erreur relative = 0.9373\n",
      "M =   200  erreur relative = 0.8748\n",
      "M =   400  erreur relative = 0.7500\n",
      "M =   800  erreur relative = 0.4999\n",
      "M =  1000  erreur relative = 0.3749\n",
      "M =  1200  erreur relative = 0.2504\n",
      "M =  1400  erreur relative = 0.1253\n",
      "M =  1600  erreur relative = 0.0000\n"
     ]
    }
   ],
   "source": [
    "# -- Reconstruction H par pseudo-inverse à partir de M paires\n",
    "def estimate_H_from_database(H_true, challenges_db, M):\n",
    "    \"\"\"\n",
    "    Reconstruit H depuis M paires (C_k, H @ C_k).\n",
    "    Retourne H_est et l'erreur relative de Frobenius.\n",
    "    \"\"\"\n",
    "    # Construire les matrices C et Y\n",
    "    C_mat = np.array(challenges_db[:M]).T          # K × M\n",
    "    Y_mat = np.array([propagate(H_true, ck) for ck in challenges_db[:M]]).T  # K × M\n",
    "\n",
    "    # Pseudo-inverse : H_est ≈ Y_mat @ pinv(C_mat)\n",
    "    H_est = Y_mat @ np.linalg.pinv(C_mat)\n",
    "    err   = np.linalg.norm(H_est - H_true, 'fro') / np.linalg.norm(H_true, 'fro')\n",
    "    return H_est, err\n",
    "\n",
    "# Test sur quelques valeurs de M (sous-ensemble car N=1600 est grand)\n",
    "M_vals14 = [10, 50, 100, 200, 400, 800, 1000, 1200, 1400, 1600]\n",
    "errors14  = []\n",
    "for M in M_vals14:\n",
    "    _, err = estimate_H_from_database(H, challenges, M)\n",
    "    errors14.append(err)\n",
    "    print(f\"M = {M:>5}  erreur relative = {err:.4f}\")"
   ]
  },
