    "\n",
    "    axes[0].semilogy(R_vals, pfp_r, color=color, lw=2, label=f'1/S={inv_s}')\n",
    "    axes[1].semilogy(R_vals, pfn_r, color=color, lw=2, label=f'1/S={inv_s}')\n",
    "\n",
    "for ax, title in zip(axes, [r'$P_{fp}$ (faux positif — Eve acceptée)',\n",
