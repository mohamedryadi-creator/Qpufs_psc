    "fig17, axes17 = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# -- Gauche : P_fp et P_fn (semilogy) vs epsilon pour plusieurs R\n",
    "mA = mu_alice(n, eta, lambda_dc)\n",
    "for R_v, col in zip(R_vals_a5, colors_a5):\n",
    "    pfp_list, pfn_list = [], []\n",
    "    for eps in eps_scan:\n",
    "        mE = mu_eve_partial(n, eta, lambda_dc, eps)\n",
    "        pfp, pfn, _ = compute_error_probs_generic(mA, mE, R_v)\n",
    "        pfp_list.append(max(pfp, EPS))\n",
    "        pfn_list.append(max(pfn, EPS))\n",
    "    axes17[0].semilogy(eps_scan, pfp_list, color=col, lw=2,\n",
    "                       label=rf'$R={R_v}$ ($P_{{\\mathrm{{fp}}}}$)')\n",
    "    axes17[0].semilogy(eps_scan, pfn_list, color=col, lw=2, ls='--')\n",
