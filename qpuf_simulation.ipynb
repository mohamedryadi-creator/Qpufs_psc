    "    n_ph  = inv_s * K\n",
    "    mA    = mu_alice(n_ph, eta_sec, ldc_sec)\n",
    "    mE4   = mu_eve_quadrature(n_ph, K, eta_sec, ldc_sec)\n",
    "    pfp_r, pfn_r = [], []\n",
    "    for R in R_vals4:\n",
    "        pfp, pfn, _ = compute_error_probs_generic(mA, mE4, R)\n",
    "        pfp_r.append(max(pfp, EPS)); pfn_r.append(max(pfn, EPS))\n",
    "    axes4[0].semilogy(R_vals4, pfp_r, color=color, lw=2, label=f'1/S={inv_s}')\n",
    "    axes4[1].semilogy(R_vals4, pfn_r, color=color, lw=2, label=f'1/S={inv_s}')\n",
    "\n",
    "for ax, title in zip(axes4, [r'$P_{fp}$', r'$P_{fn}$']):\n",
    "    ax.axhline(1e-6, color='gray', ls=':', lw=1)\n",
    "    ax.set_xlabel('Rounds $R$', fontsize=12)\n",
